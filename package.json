{
	"name": "argus",
	"private": true,
	"workspaces": [
		"packages/*",
		"packages/storage/*",
		"packages/queue/*",
		"packages/providers/*",
		"apps/*"
	],
	"type": "module",
	"scripts": {
		"build": "turbo run build",
		"typecheck": "tsc -p tsconfig.json",
		"test": "turbo run test",
		"lint": "biome lint .",
		"format": "biome format .",
		"check": "biome check .",
		"postinstall": "lefthook install"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.12",
		"@types/bun": "latest",
		"lefthook": "^2.0.15",
		"tsdown": "latest",
		"turbo": "^2.7.6",
		"typescript": "^5.9.3"
	},
	"packageManager": "bun@1.3.6"
}
